# Required: At least one API key needed
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: For fallback models
NVIDIA_MISTRAL_API_KEY=your_nvidia_mistral_key_here
NVIDIA_QWEN_API_KEY=your_nvidia_qwen_key_here
HUGGINGFACE_API_KEY=your_huggingface_key_here

# Optional: For client API key authentication (or leave empty to disable)
CLIENT_API_KEY=

# Django settings
DJANGO_SECRET_KEY=promptx-dev-secret-key
DEBUG=True

# Google OAuth (get from https://console.cloud.google.com/)
GOOGLE_OAUTH2_CLIENT_ID=your_google_client_id_here
GOOGLE_OAUTH2_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_OAUTH2_REDIRECT_URI=http://127.0.0.1:8000/auth/complete/google-oauth2/

# Razorpay Payment (get from https://dashboard.razorpay.com/)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Resend Email API (get from https://resend.com/)
RESEND_API_KEY=your_resend_api_key_here
